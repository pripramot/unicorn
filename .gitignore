apps/web/.docusaurus/
apps/web/build/

# TypeScript
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/
.nyc_output/
