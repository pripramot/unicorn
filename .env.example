# ============================================
# GTS Alpha Forensics - Environment Variables
# ============================================

# Google Pro AI (Gemini) - one.google subscription (750 THB/month)
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Google Gemma 4 (Open Model - deep reasoning + agentic)
# Served via Google AI Studio, Ollama, vLLM, or Hugging Face
GEMMA_API_KEY=your_gemma_api_key
GEMMA_MODEL=gemma-4-27b
GEMMA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# For local Ollama: GEMMA_BASE_URL=http://localhost:11434/v1

# OpenAI API
OPENAI_API_KEY=your_openai_api_key

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key

# SerpAPI (Search Intelligence)
SERPAPI_API_KEY=your_serpapi_key

# Apify (Web Scraping Automation)
APIFY_TOKEN=your_apify_token

# Supabase (Database & Auth)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_DB_PASSWORD=your_db_password
SUPABASE_DB_HOST=your_db_host
SUPABASE_DB_USER=postgres
SUPABASE_DB_PORT=5432

# Cloudflare (DDoS Protection)
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_ZONE_ID=your_zone_id

# LINE VOOM
LINE_CHANNEL_ACCESS_TOKEN=your_line_token
